# Server
PORT=3001
HOST=0.0.0.0

# CORS — comma-separated frontend origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Simulator
SIMULATOR_INTERVAL_MS=5000

# Office hours (24h format)
OFFICE_HOURS_START=9
OFFICE_HOURS_END=17

# Alert thresholds
HIGH_POWER_THRESHOLD=600
SPIKE_THRESHOLD=150

# Billing (BDT per kWh)
BILL_RATE_PER_KWH=8.4

# Database
DB_PATH=./data/voltaire.db

# Discord bot
# Create a Discord application/bot, enable Message Content Intent, then paste the token here.
DISCORD_BOT_TOKEN=
DISCORD_ALERT_CHANNEL_ID=
DISCORD_API_BASE=http://localhost:3001
DISCORD_ALERT_POLL_MS=5000
# Keep false unless you enabled Message Content Intent in Discord Developer Portal.
DISCORD_USE_MESSAGE_CONTENT_INTENT=false
# Keep false for demos so old saved alerts do not spam the channel after Docker starts.
DISCORD_POST_EXISTING_ALERTS_ON_STARTUP=false
